<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MoneyMore — Transactions tab (iOS) · Designer Prototype</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap');

:root {
  --navy:#1A3C5E; --green:#2E8B57; --green-l:#E8F5EE;
  --gold:#B8860B; --gold-l:#FBF4DC; --red:#C0392B; --red-l:#FDECEA;
  --page-bg:#F9F8F5;
  --screen-bg:#FAFAF8; --screen-bg2:#F2F0EB; --screen-bg3:#E8E5DE;
  --t1:#1A1714; --t2:#3D3A35; --t3:#7A7670; --t4:#ABA7A0;
  --t-pos:#1A6E3C; --t-neg:#A82419;
  --b1:#E8E5DF; --b2:#D4D0C8; --b3:#BCBAB2;
  --frame-bg:#2A2724; --frame-border:#1A1614;
  --f-body:'Plus Jakarta Sans',sans-serif; --f-mono:'DM Mono',monospace;
  --s-xs:10px; --s-sm:12px; --s-base:14px; --s-md:16px;
  --s-lg:18px; --s-xl:22px; --s-2xl:28px;
  --r-sm:6px; --r-md:12px; --r-lg:16px; --r-xl:24px; --r-pill:999px;
  --shadow-phone:0 8px 32px rgba(0,0,0,0.14),0 2px 8px rgba(0,0,0,0.08);
  --shadow-card:0 1px 4px rgba(0,0,0,0.06);
  --ph-w:280px; --ph-h:580px; --ph-r:36px;
}

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
body{background:var(--page-bg);font-family:var(--f-body);color:var(--t1);font-size:var(--s-base);line-height:1.6;-webkit-font-smoothing:antialiased;}
.page{max-width:1500px;margin:0 auto;padding:48px 40px 96px;}

/* ── DOC HEADER ─────────────────────────────────────────── */
.doc-header{padding-bottom:32px;margin-bottom:40px;border-bottom:2px solid var(--b1);}
.doc-meta{display:flex;align-items:center;gap:10px;margin-bottom:18px;flex-wrap:wrap;}
.doc-tag{font-family:var(--f-mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;padding:4px 11px;border-radius:3px;font-weight:600;}
.doc-tag.prototype{background:var(--green-l);color:#0F5830;}
.doc-tag.designer{background:#EAE8FF;color:#3A3288;}
.doc-tag.ios{background:#E8F0FA;color:#103868;}
.doc-tag.wip{background:var(--gold-l);color:#6B5210;}
.doc-tag.version{background:var(--navy);color:#fff;}
.doc-date{font-family:var(--f-mono);font-size:11px;color:var(--t2);margin-left:auto;font-weight:500;}
.doc-title{font-size:34px;font-weight:700;color:var(--t1);letter-spacing:-0.02em;line-height:1.15;margin-bottom:10px;}
.doc-subtitle{font-size:15px;color:var(--t1);font-weight:400;margin-bottom:30px;line-height:1.5;max-width:920px;}

.doc-info{display:grid;grid-template-columns:1fr 1fr;gap:0;border:1px solid var(--b1);border-radius:var(--r-md);overflow:hidden;background:white;}
.doc-info-cell{padding:16px 20px;border-right:1px solid var(--b1);}
.doc-info-cell:last-child{border-right:none;}
.info-label{font-family:var(--f-mono);font-size:10px;letter-spacing:0.12em;text-transform:uppercase;color:var(--t2);margin-bottom:8px;font-weight:600;}
.info-body{font-size:13px;color:var(--t1);line-height:1.55;}
.info-body strong{color:var(--t1);font-weight:700;}
.flow-list{display:flex;flex-direction:column;gap:4px;}
.flow-list-item{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--t1);line-height:1.45;}
.flow-list-item::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--green);flex-shrink:0;}

/* ── FLOW SECTION ──────────────────────────────────────── */
.flow-section{margin-bottom:64px;}
.flow-section-header{display:flex;align-items:center;gap:16px;margin-bottom:28px;}
.flow-section-line{flex:1;height:1px;background:var(--b2);}
.flow-section-title{font-family:var(--f-body);font-size:16px;font-weight:700;letter-spacing:-0.01em;color:#fff;background:var(--navy);padding:6px 14px;border-radius:4px;white-space:nowrap;}

.phone-row{display:flex;align-items:flex-start;gap:0;overflow-x:auto;padding-bottom:12px;}
.phone-row::-webkit-scrollbar{height:4px;}
.phone-row::-webkit-scrollbar-track{background:var(--b1);border-radius:2px;}
.phone-row::-webkit-scrollbar-thumb{background:var(--b3);border-radius:2px;}

.screen-col{display:flex;flex-direction:column;align-items:center;gap:10px;flex-shrink:0;}
.screen-label{font-family:var(--f-body);font-size:11px;font-weight:600;color:var(--t2);text-align:center;max-width:var(--ph-w);line-height:1.4;}

.state-badge{font-family:var(--f-mono);font-size:10px;font-weight:500;padding:3px 9px;border-radius:3px;letter-spacing:0.04em;}
.state-badge.happy{background:#EBF7F1;color:#1A6E3C;}
.state-badge.empty{background:var(--gold-l);color:#8A6510;}
.state-badge.error{background:var(--red-l);color:var(--red);}
.state-badge.loading{background:#E8F0FA;color:#103868;}
.state-badge.success{background:var(--green-l);color:#0F5830;}
.state-badge.os{background:#ECECEC;color:#555;}
.state-badge.interaction{background:#EAE8FF;color:#3A3288;}
.state-badge.warn{background:var(--gold-l);color:#8A6510;}

.flow-arrow{display:flex;flex-direction:column;align-items:center;flex-shrink:0;padding-top:calc(var(--ph-h)/2 - 16px);padding-left:6px;padding-right:6px;}
.arrow-line{width:32px;height:1px;background:var(--b2);position:relative;}
.arrow-line::after{content:'';position:absolute;right:-1px;top:-3px;border-left:5px solid var(--b2);border-top:3px solid transparent;border-bottom:3px solid transparent;}
.arrow-label{font-family:var(--f-body);font-size:10px;font-weight:600;color:var(--t2);text-align:center;max-width:80px;line-height:1.35;margin-top:6px;}
.arrow-label.deny{color:var(--red);}
.arrow-label.interaction{color:#3A3288;}

/* ── PHONE FRAME — iOS ─────────────────────────────────── */
.phone{width:var(--ph-w);height:var(--ph-h);border-radius:var(--ph-r);background:var(--frame-bg);box-shadow:var(--shadow-phone);position:relative;overflow:hidden;border:2px solid var(--frame-border);flex-shrink:0;}

.ios-island{position:absolute;top:8px;left:50%;transform:translateX(-50%);width:84px;height:24px;background:#0A0A0A;border-radius:18px;z-index:20;}
.ios-status{position:absolute;top:0;left:0;right:0;height:42px;background:var(--screen-bg);display:flex;align-items:flex-end;justify-content:space-between;padding:0 22px 6px;z-index:10;font-family:var(--f-mono);font-size:9px;font-weight:700;color:var(--t1);}
.ios-home{position:absolute;bottom:6px;left:50%;transform:translateX(-50%);width:104px;height:4px;background:rgba(0,0,0,0.28);border-radius:2px;z-index:30;}

.screen{position:absolute;top:42px;bottom:62px;left:0;right:0;background:var(--screen-bg);overflow:hidden;display:flex;flex-direction:column;}
.screen.no-nav{bottom:20px;}

/* iOS bottom nav — 5 slots with raised centre [+] */
.ios-nav{position:absolute;bottom:20px;left:0;right:0;height:42px;background:var(--screen-bg);border-top:1px solid var(--b1);display:flex;align-items:center;z-index:10;}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;padding:4px 0;}
.nav-icon{width:18px;height:18px;display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--t4);}
.nav-item.on .nav-icon{color:var(--green);}
.nav-lbl{font-size:8px;color:var(--t4);font-weight:500;}
.nav-item.on .nav-lbl{color:var(--green);font-weight:600;}
.nav-plus{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);width:46px;height:46px;border-radius:50%;background:var(--navy);display:flex;align-items:center;justify-content:center;color:#fff;font-size:24px;font-weight:300;box-shadow:0 4px 14px rgba(26,60,94,0.35);z-index:11;}
.nav-plus.active{background:var(--green);}

/* ── SCREEN INNER PRIMITIVES ───────────────────────────── */
.app-bar{height:46px;display:flex;align-items:center;padding:0 16px;background:var(--screen-bg);flex-shrink:0;gap:10px;}
.app-bar-title{font-size:var(--s-md);font-weight:700;color:var(--t1);flex:1;letter-spacing:-0.01em;}
.app-bar-action{font-size:var(--s-sm);font-weight:600;color:var(--navy);}
.back-btn{font-size:20px;color:var(--navy);line-height:1;font-weight:300;}

.sc-area{flex:1;overflow:hidden;display:flex;flex-direction:column;}
.sc-pad{padding:14px;display:flex;flex-direction:column;gap:10px;}

.t-title{font-size:var(--s-xl);font-weight:700;color:var(--t1);letter-spacing:-0.01em;line-height:1.2;}
.t-heading{font-size:var(--s-lg);font-weight:600;color:var(--t1);line-height:1.25;}
.t-body{font-size:var(--s-base);color:var(--t2);line-height:1.5;}
.t-caption{font-size:var(--s-sm);color:var(--t3);line-height:1.5;}
.t-xs{font-size:var(--s-xs);color:var(--t4);}
.t-pos{color:var(--t-pos);}
.t-neg{color:var(--t-neg);}

/* Summary bar (3-col Spent / Income / Net) */
.sum-bar{display:flex;background:#fff;border:1px solid var(--b1);border-radius:var(--r-md);padding:12px 0;box-shadow:var(--shadow-card);}
.sum-cell{flex:1;display:flex;flex-direction:column;align-items:center;gap:2px;border-right:1px solid var(--b1);padding:0 8px;}
.sum-cell:last-child{border-right:none;}
.sum-lbl{font-size:9px;font-weight:700;color:var(--t3);letter-spacing:0.06em;text-transform:uppercase;}
.sum-val{font-size:14px;font-weight:700;color:var(--t1);letter-spacing:-0.01em;}
.sum-val.pos{color:var(--t-pos);}
.sum-val.neg{color:var(--t1);}
.sum-val.net{color:var(--t1);}

/* Range pill row */
.range-row{display:flex;align-items:center;justify-content:space-between;padding:0 14px 8px;}
.range-pill{display:inline-flex;align-items:center;gap:5px;padding:5px 10px;background:var(--screen-bg2);border-radius:var(--r-pill);font-size:var(--s-xs);font-weight:600;color:var(--t2);}
.range-pill .chev{font-size:8px;color:var(--t3);}

/* Search bar */
.search-bar{display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--screen-bg2);border-radius:var(--r-sm);margin:0 14px 8px;}
.search-ico{font-size:12px;color:var(--t3);}
.search-ph{font-size:var(--s-sm);color:var(--t4);flex:1;}
.search-input{font-size:var(--s-sm);color:var(--t1);flex:1;}

/* Filter row — type tabs */
.tab-row{display:flex;gap:4px;padding:0 14px 8px;border-bottom:1px solid var(--b1);}
.tab-pill{padding:7px 12px;border-radius:var(--r-pill);font-size:var(--s-xs);font-weight:600;color:var(--t3);background:transparent;}
.tab-pill.on{background:var(--navy);color:#fff;}

/* Date preset chips row */
.chip-row{display:flex;gap:6px;padding:10px 14px;overflow-x:auto;}
.chip-row::-webkit-scrollbar{display:none;}
.date-chip{padding:5px 10px;border-radius:var(--r-pill);font-size:var(--s-xs);font-weight:600;color:var(--t2);background:#fff;border:1px solid var(--b2);white-space:nowrap;flex-shrink:0;}
.date-chip.on{background:var(--navy);color:#fff;border-color:var(--navy);}
.clear-link{margin-left:auto;font-size:var(--s-xs);font-weight:700;color:var(--navy);text-decoration:underline;align-self:center;flex-shrink:0;padding:0 4px;}

/* Date group header inside list */
.date-hdr{padding:8px 14px 4px;font-size:var(--s-xs);font-weight:700;color:var(--t3);letter-spacing:0.05em;text-transform:uppercase;background:var(--screen-bg);}

/* Transaction row */
.tx-row{display:flex;align-items:center;gap:10px;padding:11px 14px;background:#fff;border-bottom:1px solid var(--b1);}
.tx-ico{width:34px;height:34px;border-radius:var(--r-sm);background:var(--screen-bg2);display:flex;align-items:center;justify-content:center;font-size:15px;flex-shrink:0;}
.tx-info{flex:1;min-width:0;}
.tx-name{font-size:var(--s-sm);font-weight:600;color:var(--t1);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.tx-cat{font-size:var(--s-xs);color:var(--t3);margin-top:1px;}
.tx-right{text-align:right;flex-shrink:0;}
.tx-amt{font-size:var(--s-sm);font-weight:700;color:var(--t1);}
.tx-amt.pos{color:var(--t-pos);}
.tx-time{font-size:9px;color:var(--t4);margin-top:1px;}
.tx-pill{display:inline-block;padding:2px 7px;border-radius:var(--r-pill);font-size:9px;font-weight:600;background:var(--gold-l);color:#8A6510;margin-top:2px;}

/* Pending shimmer row */
.tx-row.pending .tx-ico{background:var(--screen-bg2);}
.tx-row.pending .tx-cat{color:var(--t3);font-style:italic;}
.shimmer{background:linear-gradient(90deg,var(--screen-bg2) 25%,var(--screen-bg3) 50%,var(--screen-bg2) 75%);background-size:200% 100%;animation:sh 1.4s infinite;border-radius:var(--r-sm);}
@keyframes sh{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* Empty state */
.empty-state{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px 22px;text-align:center;gap:10px;}
.empty-icon{width:58px;height:58px;border-radius:50%;background:var(--screen-bg2);display:flex;align-items:center;justify-content:center;font-size:26px;margin-bottom:4px;}
.empty-ttl{font-size:var(--s-base);font-weight:700;color:var(--t1);line-height:1.3;}
.empty-desc{font-size:var(--s-sm);color:var(--t3);line-height:1.5;max-width:240px;}
.empty-actions{display:flex;flex-direction:column;gap:8px;width:100%;max-width:220px;margin-top:12px;}

/* Buttons */
.btn{height:42px;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;font-family:var(--f-body);font-size:var(--s-sm);font-weight:700;border:none;width:100%;cursor:default;}
.btn-primary{background:var(--navy);color:#fff;}
.btn-accent{background:var(--green);color:#fff;}
.btn-outline{background:transparent;border:1.5px solid var(--navy);color:var(--navy);}
.btn-ghost{background:transparent;color:var(--navy);}
.btn-danger{background:var(--red);color:#fff;}
.btn-disabled{background:var(--screen-bg3);color:var(--t4);}
.btn-lg{height:48px;font-size:var(--s-base);}
.btn-link{background:transparent;color:var(--navy);font-weight:600;font-size:var(--s-xs);height:auto;padding:6px 0;text-decoration:underline;}

/* Form */
.form-grp{display:flex;flex-direction:column;gap:5px;}
.form-label{font-size:var(--s-xs);font-weight:700;color:var(--t2);letter-spacing:0.03em;}
.input{height:42px;border:1.5px solid var(--b2);border-radius:var(--r-sm);background:#fff;padding:0 12px;font-size:var(--s-sm);color:var(--t1);display:flex;align-items:center;}
.input.focus{border-color:var(--navy);box-shadow:0 0 0 3px rgba(26,60,94,0.07);}
.input.err{border-color:var(--red);}
.input.big{height:54px;font-size:24px;font-weight:700;}
.input-err{font-size:var(--s-xs);color:var(--red);}
.input-hint{font-size:var(--s-xs);color:var(--t3);}
.input-row{display:flex;align-items:center;justify-content:space-between;height:42px;border:1.5px solid var(--b2);border-radius:var(--r-sm);background:#fff;padding:0 12px;}
.input-row .val{font-size:var(--s-sm);color:var(--t1);font-weight:500;}
.input-row .val.ph{color:var(--t4);}
.input-row .chev{font-size:12px;color:var(--t3);}
.optional-tag{font-size:10px;color:var(--t4);font-weight:500;text-transform:none;letter-spacing:0;margin-left:4px;}

/* Toggle row */
.tog-row{display:flex;align-items:flex-start;justify-content:space-between;padding:10px 0;gap:12px;}
.tog-body{flex:1;}
.tog-lbl{font-size:var(--s-sm);color:var(--t1);font-weight:600;}
.tog-help{font-size:var(--s-xs);color:var(--t3);margin-top:3px;line-height:1.45;}
.tog{width:38px;height:22px;border-radius:var(--r-pill);background:var(--screen-bg3);position:relative;flex-shrink:0;margin-top:2px;}
.tog.on{background:var(--green);}
.tog::after{content:'';position:absolute;top:3px;left:3px;width:16px;height:16px;border-radius:50%;background:#fff;box-shadow:0 1px 2px rgba(0,0,0,0.18);}
.tog.on::after{left:19px;}

/* Sheet */
.overlay{position:absolute;inset:0;background:rgba(0,0,0,0.45);display:flex;align-items:flex-end;z-index:40;}
.sheet{background:#fff;border-radius:var(--r-xl) var(--r-xl) 0 0;width:100%;padding:14px 14px 24px;box-shadow:0 -4px 24px rgba(0,0,0,0.12);max-height:90%;overflow:hidden;display:flex;flex-direction:column;}
.sheet-handle{width:36px;height:4px;background:var(--b2);border-radius:2px;margin:0 auto 12px;}
.sheet-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.sheet-ttl{font-size:var(--s-md);font-weight:700;color:var(--t1);}
.sheet-close{font-size:18px;color:var(--t3);line-height:1;}

/* iOS-style action sheet */
.action-sheet{background:transparent;width:100%;padding:0 8px 24px;display:flex;flex-direction:column;gap:8px;}
.as-group{background:#fff;border-radius:14px;overflow:hidden;}
.as-item{padding:14px;font-size:15px;color:var(--navy);font-weight:500;text-align:center;border-bottom:1px solid var(--b1);display:flex;align-items:center;justify-content:center;gap:8px;}
.as-item:last-child{border-bottom:none;}
.as-item.cancel{font-weight:700;color:var(--red);}
.as-ico{font-size:16px;}

/* Detail sheet — view mode */
.detail-head{display:flex;align-items:center;gap:12px;padding:4px 0 14px;}
.detail-head-ico{width:42px;height:42px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;background:#1F4D5C;color:#7DDDDB;}
.detail-head-info{flex:1;min-width:0;}
.detail-head-name{font-size:15px;font-weight:700;color:var(--t1);line-height:1.2;}
.detail-head-src{font-size:var(--s-xs);color:var(--t3);margin-top:2px;}
.detail-pill{padding:4px 10px;border-radius:var(--r-pill);background:var(--screen-bg2);font-size:10px;font-weight:600;color:var(--t2);white-space:nowrap;}
.detail-pill.editing{background:var(--gold-l);color:#8A6510;}
.detail-amt-block{padding:0 0 18px;}
.detail-amt{font-size:34px;font-weight:700;color:var(--t-neg);letter-spacing:-0.02em;line-height:1;}
.detail-amt.pos{color:var(--t-pos);}
.detail-amt-ccy{font-size:18px;font-weight:600;color:var(--t-neg);margin-left:4px;letter-spacing:-0.01em;}
.detail-amt.pos .detail-amt-ccy{color:var(--t-pos);}

/* Stacked detail rows — flat, separated by hairlines (reference style) */
.detail-rows{display:flex;flex-direction:column;}
.detail-row{display:flex;align-items:center;justify-content:space-between;padding:14px 0;border-top:1px solid var(--b1);gap:12px;}
.detail-row:first-child{border-top:none;padding-top:6px;}
.detail-key{font-size:var(--s-sm);color:var(--t3);font-weight:500;flex-shrink:0;}
.detail-val{font-size:var(--s-sm);color:var(--t1);font-weight:600;text-align:right;display:flex;align-items:center;gap:6px;}
.detail-val .cat-chip{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:6px;font-size:11px;flex-shrink:0;}
.detail-val .add-link{color:var(--gold);font-weight:700;}
.detail-val .add-plus{color:var(--gold);font-weight:700;margin-right:2px;}
.detail-tog-row{display:flex;align-items:flex-start;justify-content:space-between;padding:14px 0;border-top:1px solid var(--b1);gap:12px;}
.detail-tog-body{flex:1;}
.detail-tog-lbl{font-size:var(--s-sm);color:var(--t1);font-weight:600;}
.detail-tog-help{font-size:var(--s-xs);color:var(--t3);margin-top:3px;line-height:1.4;}

/* Edit mode — field cards (reference style) */
.field-card{border:1px solid var(--b2);border-radius:var(--r-md);padding:10px 14px;background:#fff;display:flex;flex-direction:column;gap:6px;}
.field-card.focus{border-color:var(--navy);box-shadow:0 0 0 3px rgba(26,60,94,0.06);}
.field-card-lbl{font-size:var(--s-xs);font-weight:700;color:var(--t2);letter-spacing:0.04em;}
.field-card-lbl .opt{font-weight:500;color:var(--t4);text-transform:none;letter-spacing:0;margin-left:4px;}
.field-card-val{display:flex;align-items:center;justify-content:space-between;font-size:var(--s-md);color:var(--t1);font-weight:600;min-height:24px;}
.field-card-val.big{font-size:var(--s-xl);}
